{
  "rewrites": [
    {
      "source": "/api/pos",
      "destination": "https://api-dev2.materialdepot.in/apiV1/site-audit-installation-pos/"
    }
  ],
  "headers": [
    {
      "source": "/(.*\\.html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
